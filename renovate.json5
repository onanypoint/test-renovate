{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "automerge": false,
  "extends": [
    "config:best-practices",
    "group:allDigest",
  ],
  "packageRules": [
    {
      // "automerge": true,
      // "automergeType": "branch",
      "description": "pep621: group python dependency updates",
      "groupName": "python dependencies",
      "groupSlug": "uv",
      "matchDepNames": [
        "!python"
      ],
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
  ]
}