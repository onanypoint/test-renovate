{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  branchPrefix: 'chore-renovate-',
  dependencyDashboard: true,
  extends: [
    'config:best-practices',
    'group:allDigest',
    ':semanticCommitTypeAll(chore)',
  ],
  "lockFileMaintenance": {
    "enabled": true,
  },
  packageRules: [
    {
      description: 'Always create PRs for major updates',
      matchUpdateTypes: [
        'major',
      ],
      automerge: false,
    },
    // ####################################
    // EXTERNAL DEPENDENCIES
    // ####################################
    {
      description: 'External: group pin + patch updates',
      matchCategories: [
        'docker',
        'ci',
      ],
      matchUpdateTypes: ['pin', 'digest', 'patch', 'minor'],
      groupName: 'external dependencies',
      groupSlug: 'external-deps',
    },
    // EXTERNAL DEPENDENCIES MAX VERSION
    {
      description: 'Postgres: block v19+',
      matchDepNames: ['postgres'],
      allowedVersions: '<19',
    },
    {
      description: 'Elasticsearch: block v10+',
      matchDepNames: ['elasticsearch'],
      allowedVersions: '<10',
    },
    {
      description: 'Redis: block v9+',
      matchDepNames: ['redis'],
      allowedVersions: '<9',
    },
    // ####################################
    // PYTHON DEPENDENCIES
    // ####################################
    {
      description: 'pep621: pin dependency versions in pyproject.toml',
      matchCategories: ['python'],
      matchDepNames: ['!python'],
      rangeStrategy: 'pin',
      groupName: 'python dependencies',
      groupSlug: 'python-deps',
    },
    {
      description: 'Disable python updates',
      matchDepNames: ['python'],
      enabled: false,
    },
    {
      description: 'Group Django updates',
      allowedVersions: '<6',
      groupName: 'django',
      groupSlug: 'python-django',
      matchDepNames: [
        'django',
        'Django',
      ],
    },
    // ####################################
    // NPM DEPENDENCIES
    // ####################################
    {
      description: 'JS package manager: update pnpm/yarn/npm independently',
      groupName: 'js package manager',
      groupSlug: 'js-package-manager',
      matchManagers: ['npm'],
      matchDepTypes: ['packageManager'],
      rangeStrategy: 'replace',
    },
    {
      description: 'Node runtime: keep version updates separate',
      groupName: 'node',
      groupSlug: 'js-node',
      matchCategories: ['js'],
      matchPackageNames: ['node'],
      rangeStrategy: 'replace',
    },
    {
      description: 'JS: group minor updates',
      groupName: 'js dependencies (minor)',
      groupSlug: 'js-minor',
      matchCategories: ['js'],
      matchUpdateTypes: ['minor'],
    },
    {
      description: 'JS: group patch/pin/digest updates',
      groupName: 'js dependencies (patch/pin/digest)',
      groupSlug: 'js-patch-pin-digest',
      matchCategories: ['js'],
      matchUpdateTypes: ['patch', 'pin', 'digest'],
    },
  ],
}
