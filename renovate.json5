{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  branchPrefix: 'chore-renovate-',
  dependencyDashboard: true,
  extends: [
    'config:best-practices',
    'group:allDigest',
    ':semanticCommitTypeAll(chore)',
  ],
  "lockFileMaintenance": {
    "enabled": true,
  },
  packageRules: [
    {
      description: 'Always create PRs for major updates',
      matchUpdateTypes: [
        'major',
      ],
      automerge: false,
    },
    // ####################################
    // External dependencies
    // ####################################
    {
      description: 'External: group digest updates',
      matchManagers: [
        'docker-compose',
        'dockerfile',
        'gitlabci',
      ],
      matchUpdateTypes: ['pin', 'digest'],
      groupName: 'external dependencies (pin, digest)',
    },
    {
      description: 'External: group pin + patch updates',
      matchManagers: [
        'docker-compose',
        'dockerfile',
        'gitlabci',
      ],
      matchUpdateTypes: ['patch', 'minor'],
      groupName: 'external dependencies (patch, minor)',
    },
    // EXTERNAL DEPENDENCIES MAX VERSION
    {
      description: 'Postgres: block v19+',
      matchDepNames: ['postgres'],
      allowedVersions: '<19',
    },
    {
      description: 'Elasticsearch: block v10+',
      matchDepNames: ['elasticsearch'],
      allowedVersions: '<10',
    },
    {
      description: 'Redis: block v9+',
      matchDepNames: ['redis'],
      allowedVersions: '<9',
    },
    // ####################################
    // PYTHON DEPENDENCIES
    // ####################################
    {
      description: 'Disable python updates',
      matchDepNames: ['python'],
      enabled: false,
    },
    {
      description: 'pep621: pin dependency versions in pyproject.toml',
      matchManagers: ['pep621'],
      matchDepNames: ['!python'],
      rangeStrategy: 'pin',
    },
    {
      description: 'Group Django updates',
      allowedVersions: '<6',
      groupName: 'django',
      matchDepNames: [
        'django',
        'Django',
      ],
    },
  ],
}
