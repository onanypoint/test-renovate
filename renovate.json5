{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "pep621: group python dependency minor updates",
      "groupName": "python dependencies (minor)",
      "groupSlug": "uv-minor",
      "matchDepNames": [
        "!python"
      ],
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "minor"
      ]
    },
    {
      "automerge": true,
      "automergeType": "branch",
      "description": "pep621: group python dependency patch/pin/digest updates",
      "groupName": "python dependencies (patch/pin/digest)",
      "groupSlug": "uv-patch-pin-digest",
      "matchDepNames": [
        "!python"
      ],
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest"
      ]
    },

  ]
}