{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "automerge": true,
      "automergeType": "branch",
      "description": "External: group pin + patch updates",
      "groupName": "external dependencies",
      "groupSlug": "external",
      "matchCategories": [
        "docker",
        "ci"
      ],
      "matchUpdateTypes": [
        "pin",
        "digest",
        "patch"
      ],
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "groupSlug": "external",
      "automerge": false
    }
  ]
}