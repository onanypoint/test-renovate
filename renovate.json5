{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  branchPrefix: 'chore-renovate-',
  dependencyDashboard: true,
  extends: [
    'config:best-practices',
    'group:allDigest',
    ':semanticCommitTypeAll(chore)',
  ],
  "lockFileMaintenance": {
    "enabled": true,
  },
  packageRules: [
    {
      description: 'Always create PRs for major updates',
      matchUpdateTypes: [
        'major',
      ],
      automerge: false,
    },
    // ####################################
    // EXTERNAL DEPENDENCIES
    // ####################################
    {
      description: 'External: group pin + patch updates',
      matchCategories: [
        'docker',
        'ci',
      ],
      matchUpdateTypes: ['pin', 'digest', 'patch', 'minor'],
      groupName: 'external dependencies',
    },
    // EXTERNAL DEPENDENCIES MAX VERSION
    {
      description: 'Postgres: block v19+',
      matchDepNames: ['postgres'],
      allowedVersions: '<19',
    },
    {
      description: 'Elasticsearch: block v10+',
      matchDepNames: ['elasticsearch'],
      allowedVersions: '<10',
    },
    {
      description: 'Redis: block v9+',
      matchDepNames: ['redis'],
      allowedVersions: '<9',
    },
    // ####################################
    // PYTHON DEPENDENCIES
    // ####################################
    {
      description: 'pep621: pin dependency versions in pyproject.toml',
      matchCategories: ['python'],
      matchDepNames: ['!python'],
      rangeStrategy: 'pin',
      groupName: 'python dependencies (pin)'
    },
    {
      description: 'Disable python updates',
      matchDepNames: ['python'],
      enabled: false,
    },
    {
      description: 'Group Django updates',
      allowedVersions: '<6',
      groupName: 'django',
      matchDepNames: [
        'django',
        'Django',
      ],
    },
    // ####################################
    // NPM DEPENDENCIES
    // ####################################
    {
      description: 'Node runtime: keep version updates separate',
      groupName: 'node',
      matchCategories: ['js'],
      matchPackageNames: ['node'],
      rangeStrategy: 'replace',
    },
    {
      description: 'JS: group non-major updates',
      matchCategories: ['js'],
      groupName: 'js dependencies',
      matchUpdateTypes: ['patch', 'pin', 'digest', 'minor'],
    }
  ],
}
