{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "branchPrefix": "chore-renovate-",
  "dependencyDashboard": true,
  "description": "Shared base Renovate configuration preset for managing dependencies across projects",
  "extends": [
    "config:best-practices",
    "group:allDigest",
    ":semanticCommitTypeAll(chore)"
  ],
  "labels": [
    "type::renovate"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "minimumReleaseAge": "15 days",
  "packageRules": [],
  "schedule": [
    "after 4am and before 7am every weekday"
  ],
  "vulnerabilityAlerts": {
    "automerge": false,
    "enabled": true,
    "labels": [
      "type::renovate",
      "priority::high",
      "security"
    ],
    "minimumReleaseAge": null,
    "schedule": [
      "at any time"
    ]
  }
}
