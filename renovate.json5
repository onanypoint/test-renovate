{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "automerge": false,
  "extends": [
    "config:best-practices",
    "group:allDigest",
  ],
  "packageRules": [
    {
      "description": "pep621: group python dependency updates",
      "groupName": "python dependencies",
      "groupSlug": "uv",
      "matchDepNames": [
        "!python"
      ],
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest"
      ]
    },
     {
      "automerge": true,
      "automergeType": "branch",
      "description": "Automerge Python patch/pin/digest updates",
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "allowedVersions": "<16",
      "description": "Postgres: block version",
      "matchDepNames": [
        "postgres"
      ]
    },
    {
      "matchDepNames": ["postgres"],
      "enabled": false
    }
  ]
}