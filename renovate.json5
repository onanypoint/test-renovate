{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "branchPrefix": "chore-renovate-",
  "dependencyDashboard": true,
  "description": "Shared base Renovate configuration preset for managing dependencies across projects",
  "extends": [
    "config:best-practices",
    "group:allDigest",
    ":semanticCommitTypeAll(chore)"
  ],
  "labels": [
    "type::renovate"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "at any time"
    ],
  },
